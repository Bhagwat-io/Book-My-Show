(without K8S Stage)

pipeline {
    agent any
    tools {
        jdk 'jdk21'
        nodejs 'node23'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }
    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Checkout from Git') {
            steps {
                git branch: 'main', url: 'https://github.com/Bhagwat-io/Book-My-Show.git'
                sh 'ls -la'  // Verify files after checkout
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh ''' 
                    $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectKey=BMS_APP \
                    -Dsonar.projectName=BMS_APP
                    '''
                }
            }
        }
        stage('Quality Gate') {
            steps {
                script {
                    waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token'
                }
            }
        }
        stage('Install Dependencies') {
            steps {
                sh '''
                cd bookmyshow-app
                ls -la  # Verify package.json exists
                if [ -f package.json ]; then
                    rm -rf node_modules package-lock.json  # Remove old dependencies
                    npm install  # Install fresh dependencies
                else
                    echo "Error: package.json not found in bookmyshow-app!"
                    exit 1
                fi
                '''
            }
        }
        stage('Docker Build, tag  & Push') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker-cred', toolName: 'docker') {
                        sh 'docker build -t bms-app:v1.0.0 bookmyshow-app'
                        sh 'docker tag bms-app:v1.0.0 bhagwat07/bms-app:v1.0.0'
                        sh 'docker push bhagwat07/bms-app:v1.0.0'
                        
                    }
                }
            }
        }
        stage('Deploy to Container') {
            steps {
                sh ''' 
                echo "Running new container on port 3000..."
                docker run -d --restart=always --name bms-app -p 3000:3000 bhagwat07/bms-app:v1.0.0

                echo "Checking running containers..."
                docker ps -a

                echo "Fetching logs..."
                sleep 5  # Give time for the app to start
                docker logs bms-app

                '''
            }
        }
    }
    post {
        success {
            emailext (
                subject: "SUCCESS: SonarQube Quality Gate Passed",
                body: """
                Hi Team,
                
                The SonarQube quality gate passed successfully.

                You can view the report here:
                http://18.188.130.88:9000/dashboard?id=BMS_APP
                username: admin, passwd: pass

                If you want to download a PDF report, please use the SonarQube interface or a PDF plugin.

                Regards,
                Jenkins
                """,
                to: 'bhagwatkolekar8664@gmail.com'
            )
        }
        failure {
            emailext (
                subject: "FAILED: SonarQube Quality Gate",
                body: """
                Hi Team,
                
                The SonarQube quality gate has failed.
                
                Please check the details:
                http://18.188.130.88:9000/dashboard?id=BMS_APP
                username: admin, passwd: pass
                
                Regards,
                Jenkins
                """,
                to: 'bhagwatkolekar8664@gmail.com'
            )
        }
    }
}
